<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Startup Landing Page</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Header -->
<header>
    <nav>
        <h1>MyStartup</h1>
        <ul>
            <li><a href="#">Home</a></li>
            <li><a href="#">Features</a></li>
            <li><a href="#">Testimonials</a></li>
        </ul>
    </nav>
    <div class="hero">
        <h2>Welcome to Our Product</h2>
        <p>Build your future with us</p>
        <button>Get Started</button>
    </div>
</header>

<!-- Features -->
<section class="features">
    <h2>Features</h2>
    <div class="feature-container">
        <div class="card">Fast Performance</div>
        <div class="card">Secure Platform</div>
        <div class="card">Easy to Use</div>
    </div>
</section>

<!-- Testimonials -->
<section class="testimonials">
    <h2>What Users Say</h2>
    <div class="testimonial-container">
        <div class="card">"Amazing service!"</div>
        <div class="card">"Very helpful product"</div>
    </div>
</section>

<!-- Footer -->
<footer>
    <p>© 2026 MyStartup. All rights reserved.</p>
</footer>

</body>
</html>

